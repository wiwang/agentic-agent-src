# LLM Provider API Keys
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Default LLM provider: "openai" or "anthropic"
AGENTIC_DEFAULT_PROVIDER=openai
AGENTIC_DEFAULT_MODEL=gpt-4o

# Anthropic defaults
AGENTIC_ANTHROPIC_MODEL=claude-sonnet-4-6

# Logging
AGENTIC_LOG_LEVEL=INFO
AGENTIC_LOG_FORMAT=json   # "json" or "console"

# Plugin discovery directory (optional)
AGENTIC_PLUGINS_DIR=./plugins

# RAG / Vector store
AGENTIC_CHROMA_HOST=localhost
AGENTIC_CHROMA_PORT=8000
AGENTIC_CHROMA_PERSIST_DIR=./.chroma

# Embeddings: "openai" or "local"
AGENTIC_EMBEDDING_PROVIDER=local
AGENTIC_EMBEDDING_MODEL=all-MiniLM-L6-v2

# Guardrails
AGENTIC_GUARDRAILS_ENABLED=true
AGENTIC_MAX_RETRIES=3

# Evaluation
AGENTIC_EVAL_JUDGE_MODEL=gpt-4o
